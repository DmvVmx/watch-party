# Пример файла переменных окружения
# Скопируйте этот файл как .env и измените значения

# Режим работы (development/production)
NODE_ENV=production

# Порт для сервера
PORT=3000

# Домен вашего приложения (для продакшена)
DOMAIN=your-domain.com

# Максимальное количество участников в комнате
MAX_PARTICIPANTS=10

# Максимальное время жизни комнаты в часах
ROOM_MAX_AGE_HOURS=24

# Максимальное количество сообщений в истории чата
MAX_CHAT_MESSAGES=100

# Интервал очистки неактивных комнат в минутах
CLEANUP_INTERVAL_MINUTES=10